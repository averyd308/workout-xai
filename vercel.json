{
  "rewrites": [
    { "source": "/api/slack", "destination": "/api/slack" },
    { "source": "/api/cron", "destination": "/api/cron" },
    { "source": "/api/reminders", "destination": "/api/cron" },
    { "source": "/api/weekly-leaderboard", "destination": "/api/cron" },
    { "source": "/api/weekend-cron", "destination": "/api/cron" },
    { "source": "/api/strava/callback", "destination": "/api/strava_callback" },
    { "source": "/api/strava/webhook", "destination": "/api/strava_webhook" },
    { "source": "/api/workout/:path*", "destination": "/api/workout" },
    { "source": "/workout", "destination": "/workout.html" }
  ],
  "crons": [
    { "path": "/api/weekly-leaderboard", "schedule": "0 16 * * 1" },
    { "path": "/api/weekend-cron", "schedule": "0 17 * * 6,0" }
  ]
}
